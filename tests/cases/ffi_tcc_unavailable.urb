fail = 0,
info = C.info(),

/* If TCC backend is available, this fallback test is not applicable. */
if (info.tcc == 1) {
  println(0),
  return 0,
}

/* APIs must exist and fail gracefully without crashing. */
C.ffi.cdef("typedef struct { int x; } Tmp;"),
C.ffi.compile("int add(int a, int b) { return a + b; }"),
C.ffi.header("/usr/include/stdio.h"),
C.ffi.eval("sizeof(int)"),

println(fail),
