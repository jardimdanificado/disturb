fail = 0,

/* ========== 7.5: C.memory.valid ========== */

schema = { x = "int32", y = "int32" },
ptr = C.memory.new(schema),
if (ptr == null) { fail++, println("C.memory.new null"), }

/* Freshly allocated pointer should be valid */
v1 = C.memory.valid(ptr),
if (v1 != 1) { fail++, println("valid after new"), }

/* After free, should no longer be valid */
C.memory.free(ptr),
v2 = C.memory.valid(ptr),
if (v2 != 0) { fail++, println("valid after free"), }

/* Null should not be valid */
v3 = C.memory.valid(null),
if (v3 != 0) { fail++, println("valid null"), }

/* No args — should return 0 */
v4 = C.memory.valid(),
if (v4 != 0) { fail++, println("valid no args"), }

/* ========== 7.4: C.ffi.trace ========== */

/* Initially disabled */
t0 = C.ffi.trace(),
if (t0 != 0) { fail++, println("trace initial"), }

/* Enable */
t1 = C.ffi.trace(1),
if (t1 != 1) { fail++, println("trace enable"), }

/* Query */
t2 = C.ffi.trace(),
if (t2 != 1) { fail++, println("trace query"), }

/* Disable */
t3 = C.ffi.trace(0),
if (t3 != 0) { fail++, println("trace disable"), }

/* ========== 7.4: C.ffi.trace with actual FFI call ========== */

load_lib = (path){
  return C.ffi.open(path),
},

lib = load_lib("./tests/ffi/libffi_safety.so"),
if (lib == null) { lib = load_lib("./tests/ffi/libffi_safety.dylib"), }
if (lib == null) { lib = load_lib("./tests/ffi/libffi_safety.dll"), }
if (lib == null) {
  println(1),
  return 0,
}

add_sym = C.ffi.sym(lib, "safety_add"),
add = C.ffi.bind(add_sym, "int32 safety_add(int32, int32)"),

/* Enable trace, make a call, disable trace — call should still work */
C.ffi.trace(1),
r = add(10, 20),
C.ffi.trace(0),
if (r != 30) { fail++, println("trace call result"), }

/* ========== 7.2: null pointer guards (C.memory.view on null should not crash) ========== */
/* We can't easily test that the guard *prevents* a crash from .urb,
   but we can verify viewing null doesn't produce a value: */

/* C.memory.valid on random integer should return 0 */
v5 = C.memory.valid(12345),
if (v5 != 0) { fail++, println("valid random int"), }

/* ========== Done ========== */

C.ffi.close(lib),
println(fail),
