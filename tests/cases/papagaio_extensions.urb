println(papagaio("hello 123", "hello $v$int", "$v")),
println(papagaio("cost is 45.67 dollars", "cost is $c$float dollars", "$c")),
println(papagaio("my number is -89", "my number is $n$number", "$n")),
println(papagaio("HEX DEC: AB12C", "HEX DEC: $h$hex", "$h")),
println(papagaio("bin: 10110", "bin: $b$binary", "$b")),
println(papagaio("percent is 99.9%", "percent is $p$percent", "$p")),
println(papagaio("PATH /usr/bin/local", "PATH $pth$path", "$pth")),
println(papagaio("UPPERCASE", "$u$upper", "$u")),
println(papagaio("lowercase", "$l$lower", "$l")),
println(papagaio("Capitalized", "$c$capitalized", "$c")),
println(papagaio("Word", "$w$word", "$w")),
println(papagaio("test_var_1", "$i$identifier", "$i")),
println(papagaio("i want apples", "i want $fruit$aliases{apples, oranges, bananas}", "$fruit")),
println(papagaio("i want bananas", "i want $fruit$aliases{apples, oranges, bananas}", "$fruit")),
println(papagaio("optional here!", "$opt$optional{optional }here!", "$opt")),
println(papagaio("here!", "$opt$optional{optional }here!", "$opt?")),
println(papagaio("prefix_suffix", "$pre$starts{prefix_}suffix", "$pre")),
println(papagaio("prefix_suffix", "prefix_$suf$ends{_suffix}", "$suf")),
