fail = 0,

open_fixture = (path){
  return C.ffi.open(path),
},

lib = open_fixture("./tests/ffi/libffi_view_struct.so"),
if (lib == null) { lib = open_fixture("./tests/ffi/libffi_view_struct.dylib"), }
if (lib == null) { lib = open_fixture("./tests/ffi/libffi_view_struct.dll"), }
if (lib == null) {
  println(1),
  return 0,
}

ptr = C.ffi.sym(lib, "sum_variadic_i32"),
if (ptr == null) {
  fail++,
} else {
  sum = C.ffi.bind(ptr, "i32 sum_variadic_i32(i32, ...)"),
  if (sum(4, 10, 20, 30, 40) != 100) { fail++, }
}

C.ffi.close(lib),

libf = C.ffi.open("./tests/ffi/libffi_view_struct.so", C.ffi.RTLD_NOW | C.ffi.RTLD_LOCAL),
if (libf == null) { libf = C.ffi.open("./tests/ffi/libffi_view_struct.dylib", C.ffi.RTLD_NOW | C.ffi.RTLD_LOCAL), }
if (libf == null) { libf = C.ffi.open("./tests/ffi/libffi_view_struct.dll", C.ffi.RTLD_NOW | C.ffi.RTLD_LOCAL), }
if (libf == null) {
  fail++,
} else {
  ptrf = C.ffi.sym(libf, "sum_variadic_i32"),
  if (ptrf == null) { fail++, }
  C.ffi.close(libf),
}

strlen_ptr = C.ffi.symSelf("strlen"),
if (strlen_ptr == null) {
  fail++,
} else {
  strlen = C.ffi.bind(strlen_ptr, "u64 strlen(cstring)"),
  if (strlen("disturb") != 7) { fail++, }
}

bad = C.ffi.open("./tests/ffi/definitely_missing_library.so", C.ffi.RTLD_NOW),
if (bad != null) { fail++, }
derr = C.ffi.dlerror(),
if (derr == null) { fail++, }
en = C.ffi.errno(),
if (en.type != "int") { fail++, }

lib2 = open_fixture("./tests/ffi/libffi_view_struct.so"),
if (lib2 == null) { lib2 = open_fixture("./tests/ffi/libffi_view_struct.dylib"), }
if (lib2 == null) { lib2 = open_fixture("./tests/ffi/libffi_view_struct.dll"), }
if (lib2 == null) {
  fail++,
} else {
  ptr2 = C.ffi.sym(lib2, "sum_variadic_i32"),
  sum2 = C.ffi.bind(ptr2, "i32 sum_variadic_i32(i32, ...)"),
  if (sum2(3, 1, 2, 3) != 6) { fail++, }
  C.ffi.close(lib2),
}

println(fail),
