fail = 0,
info = C.info(),

if (info.tcc != 1) {
  println(0),
  return 0,
}

C.ffi.cdef("typedef int myint;"),
lib = C.ffi.compile("myint add_tcc(myint a, myint b) { return a + b; }"),
if (lib == null) { fail++, println("compile null"), }

add_tcc = C.ffi.auto(lib, "int32 add_tcc(int32, int32)"),
r1 = add_tcc(2, 3),
if (r1 != 5) { fail++, println("add_tcc " + r1), }
C.ffi.close(lib),

C.ffi.header("/usr/include/stdint.h"),
lib2 = C.ffi.compile("uint32_t inc_u32_tcc(uint32_t x) { return x + 1; }"),
if (lib2 == null) { fail++, println("compile2 null"), }
inc_u32_tcc = C.ffi.auto(lib2, "uint32 inc_u32_tcc(uint32)"),
r2 = inc_u32_tcc(9),
if (r2 != 10) { fail++, println("inc_u32_tcc " + r2), }
C.ffi.close(lib2),

v = C.ffi.eval("sizeof(int)"),
if (v < 2) { fail++, println("eval low " + v), }
if (v > 16) { fail++, println("eval high " + v), }

println(fail),
