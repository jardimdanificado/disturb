// scalar truthiness unchanged
println(!null),
println(!0),
println(!5),

// array truthiness: majority-zero -> false
x = 1 0 0,
if (x) { println("x true"), } else { println("x false"), }

y = 1 2 0,
if (y) { println("y true"), } else { println("y false"), }

z = 1 0,
if (z) { println("z true-tie"), } else { println("z false-tie"), }

// vectorized NOT
r = !(1 0 3),
println(r),

// vectorized AND
a = (1 0 1) && (1 1 0),
println(a),

// vectorized OR
b = (1 0 0) || (0 0 1),
println(b)
